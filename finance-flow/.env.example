# FinanceFlow Configuration
# Copy this file to .env and fill in your values

# Path to SQLite database file (relative or absolute)
FINANCEFLOW_DB_PATH=financeflow.db

# Default currency symbol for display
FINANCEFLOW_DEFAULT_CURRENCY=USD

# Percentage threshold for budget alerts (0-100)
FINANCEFLOW_BUDGET_ALERT_THRESHOLD=80

# Enable debug logging (true/false)
FINANCEFLOW_DEBUG=false

# Sarvam AI API key for multilingual translation support
# Get your key from https://www.sarvam.ai
SARVAM_API_KEY=your_sarvam_api_key_here
